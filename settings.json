{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "MultiEdit(*)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/shane/.claude/scripts/sync-memory.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); dir=$(basename \"$cwd\"); if git -C \"$cwd\" rev-parse --git-dir >/dev/null 2>&1; then branch=$(git -C \"$cwd\" --no-optional-locks branch --show-current 2>/dev/null || echo 'detached'); if [ -n \"$(git -C \"$cwd\" --no-optional-locks status --porcelain 2>/dev/null)\" ]; then dirty='*'; else dirty=''; fi; printf '%s %s %s%s' \"$model\" \"$dir\" \"$branch\" \"$dirty\"; else printf '%s %s' \"$model\" \"$dir\"; fi"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "superpowers@superpowers-marketplace": true,
    "superpowers-developing-for-claude-code@superpowers-marketplace": true,
    "agent-skills@addy-agent-skills": true,
    "skills-audit-business@slogsdon-claude-code-config": true,
    "skills-design@slogsdon-claude-code-config": true,
    "skills-engineering-reference@slogsdon-claude-code-config": true,
    "skills-meta-utils@slogsdon-claude-code-config": true,
    "skills-vault-knowledge@slogsdon-claude-code-config": true,
    "skills-vault-rituals@slogsdon-claude-code-config": true,
    "skills-workflows@slogsdon-claude-code-config": true,
    "skills-writing@slogsdon-claude-code-config": true
  },
  "extraKnownMarketplaces": {
    "addy-agent-skills": {
      "source": {
        "source": "github",
        "repo": "addyosmani/agent-skills"
      }
    },
    "slogsdon-claude-code-config": {
      "source": {
        "source": "github",
        "repo": "slogsdon/claude-code-config"
      }
    }
  },
  "preferredNotifChannel": "ghostty",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "defaultModel": "qwen3.6-35b-a3b",
  "defaultProvider": "lmstudio",
  "lastChangelogVersion": "0.74.0",
  "packages": [
    "npm:pi-lens",
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:@tmustier/pi-ralph-wiggum",
    "npm:@tintinweb/pi-subagents",
    "npm:@aliou/pi-guardrails",
    "npm:pi-ask-user",
    "npm:@jeonghyeon.net/pi-tasks",
    "npm:@artale/pi-memory"
  ],
  "skills": [
    "~/Code/claude-code-config/plugins/shane/skills-audit-business/skills",
    "~/Code/claude-code-config/plugins/shane/skills-design/skills",
    "~/Code/claude-code-config/plugins/shane/skills-engineering-reference/skills",
    "~/Code/claude-code-config/plugins/shane/skills-meta-utils/skills",
    "~/Code/claude-code-config/plugins/shane/skills-vault-knowledge/skills",
    "~/Code/claude-code-config/plugins/shane/skills-vault-rituals/skills",
    "~/Code/claude-code-config/plugins/shane/skills-workflows/skills",
    "~/Code/claude-code-config/plugins/shane/skills-writing/skills",
    "~/Code/claude-code-config/plugins/example-skills/skills/skills",
    "~/Code/claude-code-config/plugins/superpowers/skills",
    "~/Code/claude-code-config/plugins/superpowers-developing-for-claude-code/skills",
    "~/Code/claude-code-config/plugins/agent-skills/skills"
  ],
  "retry": {
    "enabled": true,
    "provider": {
      "timeoutMs": 7200000
    }
  },
  "enableInstallTelemetry": false,
  "defaultThinkingLevel": "medium",
  "quietStartup": true
}
