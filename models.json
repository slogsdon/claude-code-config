{
  "_comment": "Pi-compatible custom provider config. Source of truth (human-readable, with weights/reasoning notes): ~/Code/claude-code-config/models.yaml. All Pi traffic routes through LiteLLM proxy on :4000 — never direct to Ollama. Aliases renamed to use-case-oriented names 2026-05-26. Context windows default to isolated-mode values so Pi has headroom for long conversations; concurrent multi-model workloads should override num_ctx per request.",
  "workflows": {
    "default": {
      "plan": "analyze",
      "code": "code",
      "review": "review",
      "write": "write"
    }
  },
  "providers": {
    "litellm": {
      "baseUrl": "http://localhost:4000/v1",
      "api": "openai-completions",
      "apiKey": "!grep -E '^LITELLM_MASTER_KEY=' /Users/shane/Code/otel-local-ai/.env | cut -d= -f2",
      "authHeader": true,
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false
      },
      "models": [
        {
          "id": "classify",
          "name": "Cheap structured-output / triage (lfm2.5-thinking 1.2B)",
          "reasoning": true,
          "input": ["text"],
          "contextWindow": 128000,
          "maxTokens": 8192,
          "thinkingLevelMap": {
            "minimal": null,
            "low": "low",
            "medium": "medium",
            "high": "high",
            "xhigh": "high"
          }
        },
        {
          "id": "chat",
          "name": "Fast conversational (gemma4 e4b mlx)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 131072,
          "maxTokens": 16384
        },
        {
          "id": "review",
          "name": "Code review / rubric grading (granite4.1 8B)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 65536,
          "maxTokens": 16384
        },
        {
          "id": "code",
          "name": "Primary code generation (qwen2.5-coder 14B)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 65536,
          "maxTokens": 16384
        },
        {
          "id": "analyze",
          "name": "Analysis + debugging + judge (deepseek-r1 14B)",
          "reasoning": true,
          "input": ["text"],
          "contextWindow": 40960,
          "maxTokens": 16384,
          "thinkingLevelMap": {
            "off": null,
            "minimal": null,
            "low": "low",
            "medium": "medium",
            "high": "high",
            "xhigh": "high"
          }
        },
        {
          "id": "pipeline",
          "name": "Automation flows + summarization (lfm2 24B MoE)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 32768,
          "maxTokens": 16384
        },
        {
          "id": "write",
          "name": "Long-form writing (gpt-oss 20B)",
          "reasoning": true,
          "input": ["text"],
          "contextWindow": 131072,
          "maxTokens": 16384,
          "thinkingLevelMap": {
            "minimal": null,
            "low": "low",
            "medium": "medium",
            "high": "high",
            "xhigh": "high"
          }
        },
        {
          "id": "quality",
          "name": "Best local quality / long context (qwen3.6 35B mlx MoE — vision-capable)",
          "reasoning": true,
          "input": ["text", "image"],
          "contextWindow": 131072,
          "maxTokens": 16384,
          "thinkingLevelMap": {
            "minimal": null,
            "low": "low",
            "medium": "medium",
            "high": "high",
            "xhigh": "high"
          }
        }
      ]
    }
  }
}
