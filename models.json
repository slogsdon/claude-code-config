{
  "_comment": "Pi-compatible custom provider config. Source of truth (human-readable, with weights/reasoning notes): ~/Code/claude-code-config/models.yaml. All Pi traffic routes through LiteLLM proxy on :4000 — never direct to Ollama. Aliases use the tier+role scheme (fast/balanced/max tiers; structured/code/writing/reasoning roles; classify retained) migrated 2026-06-05. Context windows default to isolated-mode values so Pi has headroom for long conversations; concurrent multi-model workloads should override num_ctx per request.",
  "workflows": {
    "default": {
      "plan": "reasoning",
      "code": "code",
      "review": "balanced",
      "write": "writing"
    }
  },
  "providers": {
    "litellm": {
      "baseUrl": "http://localhost:4000/v1",
      "api": "openai-completions",
      "apiKey": "!grep -E '^LITELLM_MASTER_KEY=' /Users/shane/Code/otel-local-ai/.env | cut -d= -f2",
      "authHeader": true,
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false
      },
      "models": [
        {
          "id": "fast",
          "name": "Fast tier — triage / routing / short chat (gemma4 e4b mlx)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 131072,
          "maxTokens": 16384
        },
        {
          "id": "balanced",
          "name": "Balanced tier — solid default, review / rubric grading (granite4.1 8B)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 65536,
          "maxTokens": 16384
        },
        {
          "id": "max",
          "name": "Max tier — best local quality / long context (qwen3.6 35B mlx MoE — vision-capable)",
          "reasoning": true,
          "input": ["text", "image"],
          "contextWindow": 131072,
          "maxTokens": 16384,
          "thinkingLevelMap": {
            "minimal": null,
            "low": "low",
            "medium": "medium",
            "high": "high",
            "xhigh": "high"
          }
        },
        {
          "id": "structured",
          "name": "Structured role — fast reliable structured/JSON output (lfm2 24B MoE)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 32768,
          "maxTokens": 16384
        },
        {
          "id": "code",
          "name": "Code role — primary code generation (qwen3-coder 30B MoE)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 65536,
          "maxTokens": 16384
        },
        {
          "id": "writing",
          "name": "Writing role — long-form prose (gemma4 26B MoE)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 65536,
          "maxTokens": 16384
        },
        {
          "id": "reasoning",
          "name": "Reasoning role — analysis + debugging + judge (deepseek-r1 14B)",
          "reasoning": true,
          "input": ["text"],
          "contextWindow": 40960,
          "maxTokens": 16384,
          "thinkingLevelMap": {
            "off": null,
            "minimal": null,
            "low": "low",
            "medium": "medium",
            "high": "high",
            "xhigh": "high"
          }
        },
        {
          "id": "classify",
          "name": "Retained — cheap structured-output / triage (lfm2.5-thinking 1.2B)",
          "reasoning": true,
          "input": ["text"],
          "contextWindow": 128000,
          "maxTokens": 8192,
          "thinkingLevelMap": {
            "minimal": null,
            "low": "low",
            "medium": "medium",
            "high": "high",
            "xhigh": "high"
          }
        }
      ]
    }
  }
}
